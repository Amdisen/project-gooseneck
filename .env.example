# Gooseneck environment variables
# Copy this file to `.env.local` and fill in the values from your Supabase project.
# Supabase dashboard: Project Settings → API (URL + anon key + service role key)
#                     Project Settings → Database → Connection string (URI)

# --- Supabase (public, safe to expose to the browser) ---
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# --- Supabase (server-only, NEVER expose to the browser) ---
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# --- Postgres connection for Drizzle (server-only) ---
# Use the "Transaction" pooler connection string (port 6543) for the app runtime.
# Our db client sets prepare:false to be compatible with the transaction pooler.
DATABASE_URL="postgresql://postgres.YOUR-PROJECT-ref:YOUR-DB-PASSWORD@aws-region.pooler.supabase.com:6543/postgres"
